# ─────────────────────────────────────────────
# cngx Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── LLM Provider API Keys ──
# At least one is required for live provider calls.
# Mock adapter / offline check / quickstart work with zero keys.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Gemini adapter accepts either name (GOOGLE_API_KEY is the Google SDK alias):
GOOGLE_API_KEY=
GEMINI_API_KEY=

# ── Local proxy (optional) ──
CNGX_PROXY_HOST=127.0.0.1
CNGX_PROXY_PORT=8642

# ── Optional ──
CNGX_LOG_LEVEL=INFO
CNGX_STORAGE_DIR=.cngx
